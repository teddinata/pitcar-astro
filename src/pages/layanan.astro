---
import Layout from '~/layouts/PageLayout.astro';
import BoldCTA from '~/components/home/BoldCTA.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'Layanan Servis & Perawatan Umum',
  description:
    'Layanan bengkel mobil Pitcar Purwokerto: service mesin, oli, scanning & ECU, rem & kaki-kaki, AC, transmisi, body repair, detailing, mobil Eropa, dan emergency 24 jam.',
  canonical: 'https://pitcar.co.id/layanan',
  robots: { index: true, follow: true },
  openGraph: {
    type: 'website',
  },
};

const detailedServices = [
  {
    title: 'Mesin & Performa',
    icon: 'tabler:tool',
    desc: 'Pusat perawatan dan perbaikan jantung pacu kendaraan Anda.',
    features: [
      'Tune Up Mobil Bensin & Diesel',
      'Purging & Carbon Clean',
      'Turun Mesin (Overhaul)',
      'Servis Radiator',
    ],
  },
  {
    title: 'Pelumas & Cairan',
    icon: 'tabler:droplet',
    desc: 'Penggantian oli dan cairan vital dengan berbagai merek ternama.',
    features: [
      'Ganti Oli Mesin & Transmisi',
      'Kuras Minyak Rem',
      'Ganti Air Radiator (Coolant)',
      'Pilihan Merek: Shell, Mobil 1, Fastron, dll.',
    ],
  },
  {
    title: 'Kelistrikan & Diagnostik',
    icon: 'tabler:bolt',
    desc: 'Analisis elektronik dan kelistrikan modern menggunakan komputer canggih.',
    features: [
      'Scanning & ECU Reset',
      'Perbaikan Dinamo Ampere / Starter',
      'Perbaikan & Penggantian Aki',
      'Servis Elektrikal Sensor',
    ],
  },
  {
    title: 'Kaki-Kaki & Pengereman',
    icon: 'tabler:steering-wheel',
    desc: 'Memastikan kenyamanan dan keselamatan manuver mobil.',
    features: [
      'Servis Rem & Bubut Disc Brake',
      'Ganti Kampas Rem (Brake Pad)',
      'Rekondisi Shockbreaker',
      'Servis Rack Steer & Understeel',
    ],
  },
  {
    title: 'Sistem Pendingin AC',
    icon: 'tabler:snowflake',
    desc: 'Perawatan sistem AC agar kabin selalu sejuk dan nyaman.',
    features: [
      'Flushing AC System',
      'Isi Freon & Oli Kompresor',
      'Perbaikan Evaporator / Bocor',
      'Turun Dashboard (Heavy AC Repair)',
    ],
  },
  {
    title: 'Transmisi Mekanik & Matic',
    icon: 'tabler:settings',
    desc: 'Perbaikan sistem penyaluran daya baik ringan maupun berat.',
    features: [
      'Servis Transmisi Manual',
      'Overhaul Matic (AT, CVT, DCT, DSG)',
      'Ganti Kampas Kopling',
      'Kuras Oli Transmisi (ATF/CVTF)',
    ],
  },
  {
    title: 'Body, Cat & Detailing',
    icon: 'tabler:spray',
    desc: 'Mengembalikan estetika mobil seperti baru keluar dari dealer.',
    features: [
      'Body Repair (Penyok & Keropos)',
      'Cat Full Body / Per Panel',
      'Poles Body (Cutting & Finishing)',
      'Detailing Interior & Eksterior',
    ],
  },
  {
    title: 'Perawatan Berkala',
    icon: 'tabler:calendar-time',
    desc: 'Pemeliharaan rutin sesuai panduan kilometer.',
    features: [
      'Paket Servis 10 Ribu KM',
      'Paket Servis 40 Ribu KM (Besar)',
      'Ganti Filter Udara & Filter AC',
      'Check-up 32 Titik Kendaraan',
    ],
  },
  {
    title: 'Darurat & Home Service',
    icon: 'tabler:ambulance',
    desc: 'Penanganan darurat langsung di titik mogok kendaraan Anda.',
    features: [
      'Emergency Call 24 Jam',
      'Towing & Derek',
      'Home Service / Mekanik Panggilan',
      'Inspeksi Mobil Bekas (Di Lokasi)',
    ],
  },
];
---

<Layout metadata={metadata}>
  <!-- Breadcrumb Header -->
  <section class="relative bg-white dark:bg-[#0e0e0e] pt-32 pb-12 border-b border-black/5 dark:border-white/5 overflow-hidden not-prose">
    <div class="absolute inset-0 bg-gradient-to-b from-[#CC0000]/5 to-transparent dark:from-[#CC0000]/2 pointer-events-none"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-5 sm:px-8 flex flex-col items-center text-center">
      
      <!-- Breadcrumbs -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10 mb-6">
        <a href="/" class="text-slate-500 hover:text-[#CC0000] dark:text-slate-400 dark:hover:text-white transition-colors flex items-center">
          <Icon name="tabler:home" class="w-4 h-4" />
        </a>
        <span class="text-slate-400 dark:text-slate-600 text-sm">/</span>
        <span class="text-[#CC0000] text-sm font-semibold tracking-wide uppercase">Layanan</span>
      </div>
      
      <!-- Title -->
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-slate-900 dark:text-white uppercase tracking-tight mb-6">
        Layanan <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#CC0000] to-[#ff3333] italic">Servis & Perawatan</span>
      </h1>
      
      <!-- Description -->
      <p class="text-slate-600 dark:text-white/60 text-lg md:text-xl max-w-2xl font-light">
        Dari perawatan berkala hingga restorasi berat, spesialis mekanik Pitcar siap menangani segala jenis masalah kendaraan Anda kapan saja.
      </p>
    </div>
  </section>

  <!-- Detailed Services Grid -->
  <section class="py-20 md:py-28 bg-white dark:bg-[#0e0e0e] relative z-10">
    <div class="max-w-7xl mx-auto px-5 sm:px-8">
      
      <!-- Content header -->
      <div class="mb-16">
        <h2 class="text-3xl md:text-5xl font-black text-slate-900 dark:text-white uppercase tracking-tight">Katalog <span class="text-[#CC0000] italic">Servis</span></h2>
        <div class="w-20 h-1 bg-[#CC0000] mt-4"></div>
      </div>

      <!-- Grid Component -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {
          detailedServices.map((svc) => (
            <div class="group bg-slate-50 dark:bg-[#141414] border border-slate-200 dark:border-white/5 rounded-xl p-8 transition-all hover:-translate-y-2 hover:shadow-[0_10px_40px_rgba(204,0,0,0.1)] relative overflow-hidden">
              
              <!-- Red hover line -->
              <div class="absolute left-0 top-0 bottom-0 w-1 bg-[#CC0000] transform scale-y-0 group-hover:scale-y-100 transition-transform origin-bottom duration-300"></div>
              
              <!-- Icon Container -->
              <div class="w-14 h-14 bg-white dark:bg-[#1A1A1A] border border-slate-200 dark:border-white/10 rounded-lg flex items-center justify-center mb-6 shadow-sm group-hover:border-[#CC0000]/30 group-hover:bg-[#CC0000]/5 transition-all">
                <Icon name={svc.icon} class="w-7 h-7 text-slate-700 dark:text-white group-hover:text-[#CC0000] transition-colors" />
              </div>

              <!-- Text Content -->
              <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-3 group-hover:text-[#CC0000] transition-colors">{svc.title}</h3>
              <p class="text-slate-600 dark:text-white/60 text-sm leading-relaxed mb-6">
                {svc.desc}
              </p>

              <!-- Features List -->
              <ul class="space-y-3">
                {svc.features.map((feature) => (
                  <li class="flex items-start gap-3">
                    <Icon name="tabler:circle-check-filled" class="w-5 h-5 text-[#CC0000] flex-shrink-0 mt-[2px]" />
                    <span class="text-slate-700 dark:text-white/80 text-sm leading-tight">{feature}</span>
                  </li>
                ))}
              </ul>

            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Final Call To Action -->
  <BoldCTA />
</Layout>
