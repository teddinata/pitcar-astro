---
import Layout from '~/layouts/PageLayout.astro';

import BoldHero from '~/components/home/BoldHero.astro';
import BoldTimeline from '~/components/about/BoldTimeline.astro';
import BoldTeam from '~/components/about/BoldTeam.astro';

import ownerPitcarImg from '~/assets/images/uploads/owner-pitcar.jpg';
import sadamImg from '~/assets/images/uploads/Sadam-CO-e1673015745245.png';
import ilmanImg from '~/assets/images/uploads/Ilman-CO-e1673015703806.png';
import crossSectionImg from '~/assets/images/tentang/pitcar_cross_section.png';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'Tentang Kami',
  description:
    'Tentang Pitcar Service - Bengkel Mobil Purwokerto. One Stop Service untuk perawatan dan perbaikan mobil.',
  canonical: 'https://pitcar.co.id/tentang',
  robots: { index: true, follow: true },
  openGraph: {
    type: 'website',
  },
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->
  <BoldHero
    tagline="Muda & Berkomitmen"
    subtitle="Mengenal lebih dekat PITCAR Service, perjalanan historis, dan nilai-nilai yang kami perjuangkan demi melayani setiap langkah Anda di jalan."
    image={{
      src: ownerPitcarImg,
      alt: 'Tim Mekanik dan Manajemen PITCAR',
    }}
  >
    <Fragment slot="title">
      <h1 class="text-4xl md:text-5xl lg:text-7xl font-black italic tracking-tighter uppercase mb-4 text-slate-900 dark:text-white leading-[1.1]">
        TENTANG<br/>
        <span class="text-transparent [-webkit-text-stroke:2px_rgba(204,0,0,1)]">PITCAR</span>
      </h1>
    </Fragment>
  </BoldHero>

  <!-- Visi Section ******************* -->
  <section class="relative py-20 md:py-32 bg-slate-50 dark:bg-[#0a0a0a] overflow-hidden transition-colors duration-300">
    <!-- Decorative Accents -->
    <div class="absolute top-0 left-0 w-32 h-32 bg-[#CC0000] rounded-full blur-[120px] opacity-20"></div>
    <div class="absolute bottom-0 right-0 w-64 h-64 bg-[#CC0000] rounded-full blur-[150px] opacity-10"></div>
    
    <div class="max-w-7xl mx-auto px-5 sm:px-8 relative z-10 flex flex-col md:flex-row items-center gap-12 md:gap-20">
      <div class="md:w-1/3">
        <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full bg-[#CC0000]/10 border border-[#CC0000]/30 text-[#CC0000] text-sm font-bold uppercase tracking-widest mb-6">
          <Icon name="tabler:eye" class="w-5 h-5" />
          <span>Tujuan Utama</span>
        </div>
        <h2 class="text-5xl md:text-7xl font-black italic tracking-tighter uppercase text-slate-900 dark:text-white leading-tight transition-colors duration-300">
          VISI<br/><span class="text-transparent [-webkit-text-stroke:2px_rgba(204,0,0,1)]">KAMI</span>
        </h2>
      </div>
      <div class="md:w-2/3">
        <p class="text-xl md:text-3xl text-slate-600 dark:text-slate-300 font-medium leading-relaxed transition-colors duration-300">
          "Menjadi ekosistem perawatan mobil terbaik di Indonesia dengan mengedepankan <span class="text-slate-900 dark:text-white font-bold transition-colors duration-300">kepuasan pelanggan</span>, pelayanan prima, serta kemauan untuk terus <span class="text-[#CC0000]">berkembang bersama</span> demi memberi dampak positif kepada keluarga PITCAR, mitra, dan masyarakat luas."
        </p>
      </div>
    </div>
  </section>

  <!-- Misi Section ******************* -->
  <section class="relative py-20 md:py-32 bg-white dark:bg-[#111111] border-y border-slate-200 dark:border-white/5 transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 relative z-10">
       <div class="text-center mb-16 md:mb-24">
         <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10 text-slate-700 dark:text-slate-300 text-sm font-bold uppercase tracking-widest mb-6 transition-colors duration-300">
           <Icon name="tabler:target" class="w-5 h-5" />
           <span>Cara Kami Bekerja</span>
         </div>
         <h2 class="text-4xl md:text-6xl font-black italic tracking-tighter uppercase text-slate-900 dark:text-white transition-colors duration-300">
           MISI <span class="text-[#CC0000]">PITCAR</span>
         </h2>
       </div>

       <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-10">
         {[
           {
             title: 'Customer Centric',
             desc: 'Memberikan layanan perawatan mobil yang sepenuhnya berpusat pada kenyamanan dan kepuasan pelanggan.',
             icon: 'tabler:heart-handshake'
           },
           {
             title: 'Kualitas Premium',
             desc: 'Memberikan layanan perawatan dengan standar kualitas terbaik namun dengan harga yang tetap bersahabat.',
             icon: 'tabler:diamond'
           },
           {
             title: 'Kemudahan Ekstrem',
             desc: 'Memberikan kemudahan mutlak lewat fitur Home Service, Emergency 24 Jam, dan jaminan One Stop Service.',
             icon: 'tabler:bolt'
           },
           {
             title: 'Pemberdayaan Talenta',
             desc: 'Menggalang talenta lokal menjadi mekanik tangguh dengan pilar utama: Good Skill & Good Attitude.',
             icon: 'tabler:users-group'
           }
         ].map((misi, index) => (
           <div class="flex gap-6 p-8 rounded-2xl bg-slate-50 dark:bg-[#1a1a1a] border border-slate-200 dark:border-white/5 hover:border-[#CC0000]/40 transition-colors duration-300 group">
             <div class="flex-shrink-0 w-16 h-16 rounded-xl bg-white dark:bg-[#222] border border-slate-200 dark:border-white/10 flex items-center justify-center text-slate-500 dark:text-slate-400 group-hover:text-[#CC0000] group-hover:bg-[#CC0000]/10 transition-all duration-300 shadow-sm dark:shadow-none">
               <Icon name={misi.icon} class="w-8 h-8" />
             </div>
             <div>
               <div class="text-[#CC0000] font-black italic text-xl mb-1 opacity-50">0{index + 1}</div>
               <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2 transition-colors duration-300">{misi.title}</h3>
               <p class="text-slate-600 dark:text-slate-400 leading-relaxed transition-colors duration-300">{misi.desc}</p>
             </div>
           </div>
         ))}
       </div>
    </div>
  </section>

  <!-- Illustration Section ******************* -->
  <section class="relative py-12 bg-slate-50 dark:bg-[#0a0a0a] transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-5 sm:px-8">
      <div class="rounded-3xl overflow-hidden border border-slate-200 dark:border-white/10 shadow-2xl relative group bg-black">
        <!-- Glow -->
        <div class="absolute inset-0 bg-gradient-to-t from-[#CC0000]/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 z-10 pointer-events-none"></div>
        
        <img 
          src={typeof crossSectionImg === 'string' ? crossSectionImg : crossSectionImg.src}
          alt="Pitcar Cross Section Ecosystem" 
          class="w-full h-auto object-cover opacity-90 group-hover:opacity-100 transition-all duration-700 group-hover:scale-105" 
        />
        
        <div class="absolute bottom-6 left-6 z-20 pointer-events-none">
           <!-- Dark shadow ensures text is always readable against the image in both modes -->
           <p class="text-white font-black italic tracking-wider text-xl md:text-3xl drop-shadow-[0_4px_4px_rgba(0,0,0,0.8)]">EKOSISTEM PITCAR TERINTEGRASI</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BoldTeam Widget ************** -->
  <BoldTeam
    title="PENDIRI TERVERIFIKASI"
    subtitle="Dinakhodai oleh talenta muda engineering terbaik dengan visi mendisrupsi industri otomotif."
    members={[
      {
        name: "Ilman Naafi'an",
        role: "Co-Founder<br/>Teknik Dirgantara ITB 2014",
        image: ilmanImg,
      },
      {
        name: 'Sadam Saputra Al-Kaff',
        role: "Co-Founder<br/>Teknik Pertambangan ITB 2014",
        image: sadamImg,
      },
    ]}
  />

  <!-- Timeline Widget ****************** -->
  <BoldTimeline
    title="PERJALANAN KAMI"
    subtitle="Jejak sejarah dan milestones emas PITCAR dari tahun ke tahun."
    items={[
      {
        year: '2021',
        title: 'Februari — Berawal dari Pandemi',
        description:
          'PITCAR Service resmi didirikan di tengah merebaknya pandemi Covid-19 sebagai solusi inovatif perawatan mobil di rumah tanpa perlu was-was mendatangi kerumunan dalam antrean bengkel.',
        icon: 'tabler:rocket',
      },
      {
        year: '2021',
        title: 'Oktober — Markas Pusat',
        description:
          'Merespons tingginya orderan harian, PITCAR merekrut barisan mekanik tetap dan membangun bengkel dan garasi sentral di Jl. Pancurawis no. 14, Purwokerto Selatan.',
        icon: 'tabler:building-factory-2',
      },
      {
        year: '2022',
        title: 'Juli — 5 Startup Nasional Terbaik',
        description:
          'PITCAR terpilih dan mendapat rekognisi sebagai salah satu dari 5 Startup Betalist Telkom Nasional terbaik yang diundang untuk unjuk gigi pitching di Telkom Landmark Tower, Jakarta.',
        icon: 'tabler:award',
      },
      {
        year: '2022',
        title: 'Agustus — Layanan Darurat',
        description:
          'Mencapai 350++ basis customer loyal di wilayah Purwokerto dan sekitarnya. Merilis layanan Emergency Home Service 24 jam dan unit perawatan khusus penanganan Mobil Eropa & Amerika.',
        icon: 'tabler:tool',
      },
      {
        year: '2023',
        title: 'Migrasi Digital ERP',
        description:
          'Melakukan digitalisasi menyeluruh dengan menggunakan sistem perangkat lunak Cloud ERP mutakhir. Seluruh data stok part, riwayat servis, transaksi keuangan real-time, data mekanik, manajemen proyek hingga marketing terintegrasi secara utuh menjadi tulang punggung revolusi data-driven.',
        icon: 'tabler:database',
      },
      {
        year: '2024',
        title: 'Market Leader di Kelasnya',
        description:
          'Berekspansi sangat agresif dengan mencapai target pasar tertinggi dan menjadi market leader telak di bengkel industri otomotif lokal. Pitcar kini menampung kapasitas rata-rata 400 hingga 450 unit penerimaan servis dan perawatan setiap bulannya.',
        icon: 'tabler:chart-arrows-vertical',
      },
      {
        year: '2025',
        title: 'Ekspansi Bisnis & Sparepart',
        description:
          'Melakukan loncatan monumental ke seberang kota dengan meluncurkan operasional cabang Pitcar kedua: <strong class="text-slate-900 dark:text-white transition-colors duration-300">Otokits by Pitcar di wilayah Cilacap</strong>. Di tahun yang sama, kami melebarkan kepakan dengan mendirikan lini <strong class="text-slate-900 dark:text-white transition-colors duration-300">Pitcar Auto Part</strong> dan <strong class="text-slate-900 dark:text-white transition-colors duration-300">Pitcar Auto Accessories</strong>.',
        icon: 'tabler:building-store',
      },
    ]}
  />
</Layout>
