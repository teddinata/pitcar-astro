---
import Button from '~/components/ui/Button.astro';
import type { CallToAction } from '~/types';

interface Props {
  id?: string;
  title?: string;
  subtitle?: string;
  actions?: CallToAction[] | string;
}

const {
  id,
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  actions = await Astro.slots.render('actions'),
} = Astro.props;
---

<section
  class="bold-cta relative py-20 md:py-28 overflow-hidden not-prose"
  {...id ? { id } : {}}
>
  <!-- Background -->
  <div class="absolute inset-0 bg-slate-50 dark:bg-[#0a0a0a] transition-colors duration-300"></div>

  <!-- Diagonal orange stripes background -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="bold-cta__stripes"></div>
  </div>

  <!-- Glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] bg-[#CC0000]/10 blur-[80px] rounded-full pointer-events-none"></div>

  <!-- Orange borders -->
  <div class="absolute top-0 left-0 right-0 h-[3px] bg-gradient-to-r from-transparent via-[#CC0000] to-transparent"></div>
  <div class="absolute bottom-0 left-0 right-0 h-[3px] bg-gradient-to-r from-transparent via-[#CC0000]/50 to-transparent"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-5 sm:px-8 text-center">

    <!-- Label -->
    <div class="flex items-center justify-center gap-3 mb-5">
      <div class="w-8 h-[3px] bg-[#CC0000]"></div>
      <span class="text-[#CC0000] text-xs font-bold uppercase tracking-[0.3em]">Booking Sekarang</span>
      <div class="w-8 h-[3px] bg-[#CC0000]"></div>
    </div>

    <!-- Headline -->
    {title && (
      <h2 class="bold-cta__title text-4xl md:text-6xl font-black text-slate-900 dark:text-white uppercase tracking-tight leading-none mb-4">
        <Fragment set:html={title} />
      </h2>
    )}

    <!-- Border accent -->
    <div class="flex justify-center mb-5">
      <div class="w-16 h-[3px] bg-[#CC0000]"></div>
    </div>

    <!-- Subtitle -->
    {subtitle && (
      <p class="text-slate-600 dark:text-white/55 text-base md:text-lg leading-relaxed mb-8 max-w-2xl mx-auto">
        <Fragment set:html={subtitle} />
      </p>
    )}

    <!-- Actions -->
    {actions && (
      <div class="flex flex-wrap justify-center gap-4">
        {Array.isArray(actions) ? (
          actions.map((action) => (
            <Button {...(action || {})} class="bold-cta__btn" />
          ))
        ) : (
          <Fragment set:html={actions} />
        )}
      </div>
    )}

    <!-- Trust text -->
    <p class="mt-6 text-slate-400 dark:text-white/25 text-xs uppercase tracking-widest">
      Gratis General Check Up • Hanya 5 slot setiap harinya
    </p>
  </div>
</section>

<style>
  .bold-cta__stripes {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 30px,
      rgba(204, 0, 0, 0.03) 30px,
      rgba(204, 0, 0, 0.03) 32px
    );
  }

  .bold-cta__title :global(br) {
    display: none;
  }

  /* Override primary button for CTA */
  .bold-cta :global(.btn-primary) {
    background-color: #CC0000 !important;
    border-color: #CC0000 !important;
    color: white !important;
    font-weight: 700;
    font-size: 1rem;
    padding: 1rem 2.5rem;
    border-radius: 4px;
    letter-spacing: 0.02em;
    box-shadow: 0 4px 30px rgba(204, 0, 0, 0.5);
    transition: all 0.2s ease;
  }

  .bold-cta :global(.btn-primary:hover) {
    background-color: #E61a1a !important;
    border-color: #E61a1a !important;
    box-shadow: 0 8px 40px rgba(204, 0, 0, 0.6);
    transform: translateY(-2px);
  }
</style>
