---
import Image from '~/components/common/Image.astro';
import type { ImageMetadata } from 'astro';

interface StepItem {
  title: string;
  description: string;
  icon?: string;
}

interface Props {
  id?: string;
  title?: string;
  subtitle?: string;
  items?: StepItem[];
  image?: { src: ImageMetadata | string; alt: string };
}

const {
  id,
  title = 'Alur Pemesanan',
  subtitle = 'Mudahnya pesan layanan Pitcar dari ponsel Anda.',
  items = [],
  image,
} = Astro.props;
---

<section
  class="bold-process relative py-20 md:py-28 overflow-hidden not-prose"
  {...id ? { id } : {}}
>
  <!-- Background -->
  <div class="absolute inset-0 bg-slate-50 dark:bg-[#0d0d0d] transition-colors duration-300"></div>
  <div class="absolute top-0 left-0 right-0 h-[3px] bg-gradient-to-r from-transparent via-[#CC0000] to-transparent"></div>
  <div class="absolute bottom-0 left-0 right-0 h-[3px] bg-gradient-to-r from-transparent via-[#CC0000]/30 to-transparent"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-5 sm:px-8">

    <!-- Section header -->
    <div class="text-center mb-16">
      <div class="flex items-center justify-center gap-3 mb-3">
        <div class="w-8 h-[3px] bg-[#CC0000]"></div>
        <span class="text-[#CC0000] text-xs font-bold uppercase tracking-[0.3em]">Proses</span>
        <div class="w-8 h-[3px] bg-[#CC0000]"></div>
      </div>
      <h2 class="text-3xl md:text-5xl font-black text-slate-900 dark:text-white uppercase tracking-tight">{title}</h2>
      <p class="text-slate-600 dark:text-white/45 text-base mt-3 max-w-md mx-auto">{subtitle}</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Steps -->
      <div class="relative">
        <!-- Vertical connecting line -->
        <div class="absolute left-[22px] top-8 bottom-8 w-px bg-gradient-to-b from-[#CC0000] via-[#CC0000]/40 to-transparent hidden sm:block"></div>

        <div class="flex flex-col gap-6">
          {items.map((item, i) => (
            <div class="relative flex gap-5 group">
              <!-- Step number circle -->
              <div class="bold-process__step-num flex-shrink-0 relative z-10">
                <div class="w-11 h-11 rounded-full bg-white dark:bg-[#141414] border-2 border-[#CC0000]/40 flex items-center justify-center transition-all group-hover:border-[#CC0000] group-hover:bg-[#CC0000]/10">
                  <span class="text-[#CC0000] font-black text-sm">{String(i + 1).padStart(2, '0')}</span>
                </div>
              </div>

              <!-- Content -->
              <div class="bold-process__step-content flex-1 pb-2 transition-all">
                <h3
                  class="text-slate-900 dark:text-white font-bold text-base mb-1 leading-tight group-hover:text-[#CC0000] transition-colors"
                  set:html={item.title}
                />
                <p class="text-slate-500 dark:text-white/45 text-sm leading-relaxed">{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Image -->
      {image && (
        <div class="relative">
          <div class="absolute -top-3 -right-3 w-16 h-16 border-t-2 border-r-2 border-[#CC0000] z-20"></div>
          <div class="absolute -bottom-3 -left-3 w-16 h-16 border-b-2 border-l-2 border-[#CC0000]/40 z-20"></div>
          <div class="relative overflow-hidden rounded">
            <Image
              class="w-full h-[380px] lg:h-[480px] object-cover"
              widths={[400, 768]}
              sizes="(max-width: 768px) 100vw, 50vw"
              width={600}
              height={480}
              loading="lazy"
              src={image.src}
              alt={image.alt}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 h-1 bg-[#CC0000]"></div>
          </div>
        </div>
      )}
    </div>
  </div>
</section>
