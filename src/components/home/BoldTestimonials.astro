---
import Image from '~/components/common/Image.astro';
import type { ImageMetadata } from 'astro';

interface TestimonialItem {
  testimonial?: string;
  name?: string;
  job?: string;
  image?: { src: ImageMetadata | string; alt: string };
}

interface Props {
  id?: string;
  title?: string;
  tagline?: string;
  testimonials?: TestimonialItem[];
}

const {
  id,
  title = 'Kata Mereka Tentang PITCAR',
  tagline = 'Testimoni',
  testimonials = [],
} = Astro.props;
---

<section
  class="bold-testimonials relative py-20 md:py-28 overflow-hidden not-prose"
  {...id ? { id } : {}}
>
  <!-- Background -->
  <div class="absolute inset-0 bg-slate-50 dark:bg-[#080808] transition-colors duration-300"></div>

  <!-- Background detail -->
  <div class="absolute right-0 top-0 bottom-0 w-1/3 bg-gradient-to-l from-[#CC0000]/5 to-transparent pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-5 sm:px-8">

    <!-- Section header -->
    <div class="mb-12">
      <div class="flex items-center gap-3 mb-3">
        <div class="w-8 h-[3px] bg-[#CC0000]"></div>
        <span class="text-[#CC0000] text-xs font-bold uppercase tracking-[0.3em]">{tagline}</span>
      </div>
      <h2 class="text-3xl md:text-5xl font-black text-slate-900 dark:text-white uppercase tracking-tight leading-tight">
        {title}
      </h2>
    </div>

    <!-- Testimonial cards -->
    <div class="grid sm:grid-cols-2 gap-5 md:gap-6">
      {testimonials.map(({ testimonial, name, job, image }) => (
        <div class="bold-testimonial-card group relative bg-white dark:bg-[#111111] border border-slate-200 dark:border-white/[0.06] rounded shadow-sm dark:shadow-none overflow-hidden transition-all duration-300 hover:border-[#CC0000]/30 p-6 md:p-8">
          <!-- Left orange accent bar -->
          <div class="absolute left-0 top-0 bottom-0 w-[3px] bg-[#CC0000] opacity-60 group-hover:opacity-100 transition-opacity"></div>

          <!-- Big quote mark -->
          <div class="text-7xl font-black text-slate-100 dark:text-white/[0.05] leading-none mb-1 select-none font-serif">"</div>

          <!-- Testimonial text -->
          {testimonial && (
            <blockquote class="text-slate-600 dark:text-white/65 text-sm md:text-base leading-relaxed mb-6">
              {testimonial}
            </blockquote>
          )}

          <!-- Author -->
          <div class="flex items-center gap-3 pt-4 border-t border-slate-200 dark:border-white/[0.06]">
            {image && (
              <div class="w-10 h-10 rounded-full overflow-hidden border border-[#CC0000]/30 flex-shrink-0">
                {typeof image === 'string' ? (
                  <Fragment set:html={image} />
                ) : (
                  <Image
                    class="w-10 h-10 object-cover"
                    width={40}
                    height={40}
                    widths={[80]}
                    loading="lazy"
                    layout="fixed"
                    src={image.src}
                    alt={image.alt || name || ''}
                  />
                )}
              </div>
            )}
            <div>
              {name && <p class="text-slate-900 dark:text-white font-bold text-sm">{name}</p>}
              {job && <p class="text-[#CC0000] text-xs font-medium">{job}</p>}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .bold-testimonial-card:hover {
    box-shadow: 0 8px 40px rgba(204, 0, 0, 0.08);
    transform: translateY(-2px);
  }
</style>
