---
const stats = [
  {
    number: '19jt+',
    title: 'Mobil Penumpang',
    description: 'Proyeksi jumlah mobil penumpang di Indonesia tahun 2025 (BPS)',
  },
  {
    number: '6jt+',
    title: 'Mobil Barang',
    description: 'Proyeksi jumlah mobil barang di Indonesia tahun 2025 (BPS)',
  },
  {
    number: '450+',
    title: 'Unit/Bulan',
    description: 'Volume layanan PITCAR Service saat ini di Purwokerto',
  },
];
---

<section class="py-16 bg-white dark:bg-slate-900 transition-colors duration-300">
  <div class="container mx-auto px-4 max-w-6xl">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-800 dark:text-white mb-4">Potensi Pasar yang Besar</h2>
      <p class="text-gray-600 dark:text-gray-300 max-w-3xl mx-auto">
        Jumlah kendaraan di Indonesia terus bertumbuh pesat setiap tahunnya, menciptakan peluang bisnis yang sangat
        menjanjikan di industri perawatan mobil.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {
        stats.map((stat) => (
          <div class="bg-gray-50 dark:bg-slate-800 p-8 rounded-xl text-center">
            <div class="text-5xl font-bold text-primary dark:text-red-500 mb-4">{stat.number}</div>
            <h3 class="text-xl font-semibold mb-2 dark:text-white">{stat.title}</h3>
            <p class="text-gray-600 dark:text-gray-300">{stat.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
