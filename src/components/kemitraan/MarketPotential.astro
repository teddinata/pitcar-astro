---
const stats = [
  {
    number: '19jt+',
    title: 'Mobil Penumpang',
    description: 'Proyeksi jumlah mobil penumpang di Indonesia tahun 2025 (BPS)',
  },
  {
    number: '6jt+',
    title: 'Mobil Barang',
    description: 'Proyeksi jumlah mobil barang di Indonesia tahun 2025 (BPS)',
  },
  {
    number: '450+',
    title: 'Unit/Bulan',
    description: 'Volume layanan PITCAR Service saat ini di Purwokerto',
  },
];
---

<section class="py-20 bg-slate-50 dark:bg-[#080808] border-t border-slate-200 dark:border-white/5">
  <div class="container mx-auto px-4 max-w-6xl">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-black text-slate-900 dark:text-white mb-4 uppercase tracking-tight">Kapasitas Pasar Luas</h2>
      <p class="text-slate-600 dark:text-white/60 text-lg max-w-3xl mx-auto font-light">
        Jumlah kendaraan di Indonesia terus bertumbuh pesat setiap tahunnya, membuktikan bahwa industri perawatan mobil merupakan bisnis yang kebal krisis.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {
        stats.map((stat) => (
          <div class="bg-white dark:bg-[#141414] p-10 rounded-2xl text-center border border-slate-200 dark:border-white/5 hover:border-[#CC0000]/30 hover:shadow-2xl hover:shadow-[#CC0000]/10 hover:-translate-y-1 transition-all duration-300">
            <div class="text-6xl font-black text-[#CC0000] mb-4 tracking-tighter">{stat.number}</div>
            <h3 class="text-xl font-bold mb-3 text-slate-900 dark:text-white uppercase tracking-wide">{stat.title}</h3>
            <p class="text-slate-600 dark:text-white/60 text-sm leading-relaxed">{stat.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
