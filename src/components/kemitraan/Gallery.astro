---
import { Image } from 'astro:assets';
import pitcarFasad from '~/assets/images/kemitraan/pitcar-fasad.webp';
import pitcarRuangTunggu from '~/assets/images/kemitraan/pitcar-ruang-tunggu.webp';
import pitcarStall from '~/assets/images/kemitraan/pitcar-stall.webp';
import pitcarStall2 from '~/assets/images/kemitraan/pitcar-stall-2.webp';

const galleryImages = [
  {
    id: 1,
    src: pitcarFasad,
    alt: 'PITCAR Service - Fasade Bengkel',
    title: 'Fasad Bengkel Modern',
  },
  {
    id: 2,
    src: pitcarRuangTunggu,
    alt: 'PITCAR Service - Ruang Tunggu',
    title: 'Ruang Tunggu Nyaman',
  },
  {
    id: 3,
    src: pitcarStall,
    alt: 'PITCAR Service - Stall Servis',
    title: 'Stall Servis Lengkap',
  },
  {
    id: 4,
    src: pitcarStall2,
    alt: 'PITCAR Service - Stall Servis 2',
    title: 'Antrian Pengerjaan Servis',
  },
];
---

<section id="gallery" class="py-20 bg-white dark:bg-[#080808] border-t border-slate-200 dark:border-white/5">
  <div class="container mx-auto px-4 max-w-6xl">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-black text-slate-900 dark:text-white mb-4 uppercase tracking-tight">
        Fasilitas <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#CC0000] to-[#ff4444] italic">Premium</span>
      </h2>
      <p class="text-slate-600 dark:text-white/60 text-lg max-w-3xl mx-auto font-light">
        Standar outlet Pitcar dengan ruang tunggu VIP dan area stall dengan tools spesialis modern.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-6">
      {
        galleryImages.map((image) => (
          <div class="group relative overflow-hidden rounded-2xl border border-slate-200 dark:border-white/5 hover:border-[#CC0000]/30 shadow-2xl hover:shadow-[#CC0000]/10 transition-all duration-500 cursor-pointer">
            <Image
              src={image.src}
              alt={image.alt}
              class="w-full h-72 object-cover transform group-hover:scale-110 transition-transform duration-700"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[#080808] via-black/40 to-transparent opacity-60 group-hover:opacity-90 transition-opacity duration-300"></div>
            <div class="absolute bottom-0 left-0 right-0 p-8 transform translate-y-2 group-hover:translate-y-0 transition-transform duration-300">
              <div class="w-10 h-1 bg-[#CC0000] mb-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300 delay-100"></div>
              <h3 class="text-2xl font-bold text-white uppercase tracking-wide">{image.title}</h3>
            </div>
          </div>
        ))
      }
    </div>

    <div class="text-center mt-16">
      <a
        href="#contact"
        class="inline-block bg-transparent hover:bg-[#CC0000] border-2 border-[#CC0000] hover:border-transparent text-slate-900 dark:text-white hover:text-white focus:outline-none focus:ring-4 focus:ring-[#CC0000]/50 font-bold py-4 px-10 rounded-xl text-lg uppercase tracking-widest transition-all duration-300 shadow-lg hover:shadow-[#CC0000]/30"
      >
        Jadwalkan Kunjungan Ke Lokasi
      </a>
    </div>
  </div>
</section>
