---

<section id="process" class="py-20 bg-white dark:bg-[#080808] border-t border-slate-200 dark:border-white/5">
  <div class="container mx-auto px-4 max-w-6xl">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-black text-slate-900 dark:text-white mb-4 uppercase tracking-tight">
        Alur <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#CC0000] to-[#ff4444] italic">Kerjasama</span>
      </h2>
      <p class="text-slate-600 dark:text-white/60 text-lg max-w-3xl mx-auto font-light">
        Proses menjadi mitra franchise PITCAR Service didesain transparan, cepat, dan profesional.
      </p>
    </div>
    <div class="flex flex-col md:flex-row justify-between items-start mb-16 relative">
      <div class="hidden md:block absolute top-10 left-[10%] right-[10%] h-0.5 bg-gradient-to-r from-transparent via-[#CC0000]/30 to-transparent z-0"></div>
      
      <div class="timeline-step text-center mb-8 md:mb-0 relative z-10 w-full md:w-1/5 group">
        <div class="bg-slate-50 dark:bg-[#141414] border-2 border-[#CC0000] group-hover:bg-[#CC0000] group-hover:shadow-[0_0_15px_rgba(204,0,0,0.5)] w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6 transition-all duration-300">
          <span class="text-[#CC0000] group-hover:text-white font-black text-2xl transition-colors duration-300">1</span>
        </div>
        <h3 class="font-bold text-slate-900 dark:text-white text-lg uppercase tracking-wide mb-2">Pengajuan</h3>
        <p class="text-slate-600 dark:text-white/50 text-sm leading-relaxed px-2">Isi formulir pendaftaran awal</p>
      </div>
      
      <div class="timeline-step text-center mb-8 md:mb-0 relative z-10 w-full md:w-1/5 group">
        <div class="bg-slate-50 dark:bg-[#141414] border-2 border-[#CC0000] group-hover:bg-[#CC0000] group-hover:shadow-[0_0_15px_rgba(204,0,0,0.5)] w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6 transition-all duration-300">
          <span class="text-[#CC0000] group-hover:text-white font-black text-2xl transition-colors duration-300">2</span>
        </div>
        <h3 class="font-bold text-slate-900 dark:text-white text-lg uppercase tracking-wide mb-2">Proposal</h3>
        <p class="text-slate-600 dark:text-white/50 text-sm leading-relaxed px-2">Terima dan pelajari dokumen proposal kemitraan</p>
      </div>
      
      <div class="timeline-step text-center mb-8 md:mb-0 relative z-10 w-full md:w-1/5 group">
        <div class="bg-slate-50 dark:bg-[#141414] border-2 border-[#CC0000] group-hover:bg-[#CC0000] group-hover:shadow-[0_0_15px_rgba(204,0,0,0.5)] w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6 transition-all duration-300">
          <span class="text-[#CC0000] group-hover:text-white font-black text-2xl transition-colors duration-300">3</span>
        </div>
        <h3 class="font-bold text-slate-900 dark:text-white text-lg uppercase tracking-wide mb-2">Pitching</h3>
        <p class="text-slate-600 dark:text-white/50 text-sm leading-relaxed px-2">Sesi presentasi dan diskusi bisnis mendalam</p>
      </div>
      
      <div class="timeline-step text-center mb-8 md:mb-0 relative z-10 w-full md:w-1/5 group">
        <div class="bg-slate-50 dark:bg-[#141414] border-2 border-[#CC0000] group-hover:bg-[#CC0000] group-hover:shadow-[0_0_15px_rgba(204,0,0,0.5)] w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6 transition-all duration-300">
          <span class="text-[#CC0000] group-hover:text-white font-black text-2xl transition-colors duration-300">4</span>
        </div>
        <h3 class="font-bold text-slate-900 dark:text-white text-lg uppercase tracking-wide mb-2">Verifikasi</h3>
        <p class="text-slate-600 dark:text-white/50 text-sm leading-relaxed px-2">Survei dan analisis kelayakan ruko/lokasi</p>
      </div>
      
      <div class="timeline-step text-center relative z-10 w-full md:w-1/5 group">
        <div class="bg-slate-50 dark:bg-[#141414] border-2 border-[#CC0000] group-hover:bg-[#CC0000] group-hover:shadow-[0_0_15px_rgba(204,0,0,0.5)] w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6 transition-all duration-300">
          <span class="text-[#CC0000] group-hover:text-white font-black text-2xl transition-colors duration-300">5</span>
        </div>
        <h3 class="font-bold text-slate-900 dark:text-white text-lg uppercase tracking-wide mb-2">Go-Live</h3>
        <p class="text-slate-600 dark:text-white/50 text-sm leading-relaxed px-2">Tanda tangan kontrak, renovasi, dan opening outlet</p>
      </div>
    </div>
    
    <div class="text-center">
      <a
        href="#contact"
        class="inline-block bg-transparent border-2 border-[#CC0000] text-slate-900 dark:text-white hover:bg-[#CC0000] focus:ring-4 focus:ring-[#CC0000]/50 hover:text-white font-bold py-4 px-10 rounded-xl text-lg uppercase tracking-widest transition duration-300 shadow-lg"
      >
        Mulai Proses Sekarang
      </a>
    </div>
  </div>
</section>
